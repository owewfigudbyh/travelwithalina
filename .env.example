# Пример файла .env
# Скопируйте этот файл в .env и заполните своими данными

# ═══════════════════════════════════════════════════════════════
# OpenAI API
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ═══════════════════════════════════════════════════════════════
# Facebook Page Access Token
# Получите на: https://developers.facebook.com/apps/
# ═══════════════════════════════════════════════════════════════
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# ═══════════════════════════════════════════════════════════════
# Telegram Bot (для уведомлений менеджеру)
# Создайте бота через @BotFather
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_GROUP_ID=-1001234567890

# ═══════════════════════════════════════════════════════════════
# TourVisor API (опционально)
# Для интеграции с системой бронирования
# ═══════════════════════════════════════════════════════════════
TOURVISOR_LOGIN=your_email@example.com
TOURVISOR_PASSWORD=your_password_here

